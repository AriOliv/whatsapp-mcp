# ─────────────────────────────────────────────────────────────────────────────
# Shared — Evolution API backend
# ─────────────────────────────────────────────────────────────────────────────
# Base URL of the Evolution API (use 127.0.0.1, not localhost — Node may resolve
# localhost to IPv6 ::1 while the API listens on IPv4).
EVO_BASE_URL=http://127.0.0.1:8080

# ─────────────────────────────────────────────────────────────────────────────
# stdio transport (single user / local) — src/index.ts
# ─────────────────────────────────────────────────────────────────────────────
# The server's AUTHENTICATION_API_KEY (global key) OR an instance key.
EVO_API_KEY=429683C4C977415CAAFCCE10F7D57E11
# Active instance name (the {instance} segment auto-filled in instance-scoped
# tools). Can also be set at runtime via evo_use_instance; persisted to
# ~/.evoapi-mcp.json.
EVO_INSTANCE=aol-rj

# ─────────────────────────────────────────────────────────────────────────────
# HTTP transport (remote / multi-tenant) — src/http-server.ts
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
# Public origin the MCP client and OAuth flow are reached at (no trailing slash).
PUBLIC_URL=http://localhost:3000
# Secret used to sign MCP access tokens (>= 32 chars). Generate a strong one.
MCP_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Global key used to CREATE / manage per-user instances during pairing.
EVO_GLOBAL_API_KEY=429683C4C977415CAAFCCE10F7D57E11
# Prefix for auto-created per-user instances (pairing creates <prefix><flowId>).
EVO_INSTANCE_PREFIX=mcp-
